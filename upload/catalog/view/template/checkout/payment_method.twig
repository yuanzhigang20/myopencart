<fieldset class="checkout-method-card">
  <legend class="visually-hidden">Payment</legend>
  <input type="hidden" name="payment_method" value="{{ code }}" id="input-payment-code">
  <div id="error-payment-method" class="invalid-feedback d-block mt-2"></div>

  <div class="mt-3">
    <label for="input-comment" class="form-label"><strong>Order Notes</strong></label>
    <textarea name="comment" rows="3" id="input-comment" class="form-control" placeholder="Optional delivery notes. Please do not include payment information here.">{{ comment }}</textarea>
    <div class="form-text">Private note for delivery or order handling.</div>
  </div>
  {% if text_agree %}
    <div class="form-check mt-3">
      <input type="checkbox" name="agree" value="1" id="input-checkout-agree" class="form-check-input" {% if agree %}checked{% endif %}>
      <label for="input-checkout-agree" class="form-check-label">{{ text_agree|raw }}</label>
    </div>
  {% endif %}
</fieldset>
