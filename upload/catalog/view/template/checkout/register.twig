  <div class="row row-cols-1 row-cols-md-2 d-none">
    <div id="password" class="col mb-2">
      <fieldset>
        <legend>{{ text_your_password }}</legend>
        <div class="row">
          <div class="col mb-3">
            <label for="input-password" class="form-label">{{ entry_password }}</label> <input type="password" name="password" value="" placeholder="{{ entry_password }}" id="input-password" class="form-control" data-register-required="1"/>
            <div id="error-password" class="invalid-feedback"></div>
          </div>
        </div>
      </fieldset>
