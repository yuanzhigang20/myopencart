<div class="card product-card h-100 border-0 shadow-sm">
  <a href="{{ href }}"><img src="{{ thumb }}" alt="{{ name }}" class="card-img-top"></a>
  <div class="card-body d-flex flex-column">
    <h3 class="h6 fw-bold"><a class="text-decoration-none text-dark" href="{{ href }}">{{ name }}</a></h3>
    <p class="text-muted small flex-grow-1">{{ description }}</p>
    {% if price %}<div class="price mb-3">{{ price }}</div>{% endif %}
    <a class="btn btn-primary mt-auto" href="{{ href }}">View product</a>
  </div>
</div>
