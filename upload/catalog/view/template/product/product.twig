{{ header }}
<main class="container py-4">
  <nav aria-label="breadcrumb" class="mb-3"><ol class="breadcrumb small">{% for breadcrumb in breadcrumbs %}<li class="breadcrumb-item{% if loop.last %} active{% endif %}">{% if not loop.last %}<a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a>{% else %}{{ breadcrumb.text }}{% endif %}</li>{% endfor %}</ol></nav>
<div class="row g-4 mb-4 align-items-start">

  {% if thumb or images %}
  <div class="col-lg-6">
    <div class="image magnific-popup product-gallery-main">
      {% if thumb %} <a href="{{ popup }}" title="{{ heading_title }}"><img src="{{ thumb }}" title="{{ heading_title }}" alt="{{ heading_title }}" class="img-fluid" loading="eager"/></a> {% endif %}

      {% if images %}
      <div class="d-flex flex-wrap gap-2 p-3">
        {% for image in images %} <a href="{{ image.popup }}" title="{{ heading_title }}"><img src="{{ image.thumb }}" title="{{ heading_title }}" alt="{{ heading_title }}" class="img-thumbnail" loading="lazy" style="width: 74px; height:74px; object-fit:cover; border-radius:14px"/></a>&nbsp;
        {% endfor %}
      </div>
      {% endif %}

    </div>
  </div>
  {% endif %}

  <div class="col-lg-6">
    <div class="product-summary-card">
    <span class="wellness-kicker mb-2">Private wellness product</span>
    <h1 class="fw-bold mb-3">{{ heading_title }}</h1>
    <div class="product-badges mb-3"><span class="wellness-pill">18+ only</span><span class="wellness-pill">Discreet packaging</span><span class="wellness-pill">Secure checkout</span><span class="wellness-pill">Body-safe focus</span></div>

    <ul class="list-unstyled mb-3 small text-muted">
      {% if manufacturer %}
      <li>{{ text_manufacturer }}: <strong><a href="catalog/manufacturer/manufacturer-{{ manufacturer_id }}">{{ manufacturer }}</a></strong></li>
      {% endif %}

      <li>{{ text_model }}: <strong>{{ model }}</strong></li>
      {% for product_code in product_codes %}
      <li>{{ product_code.code }}: <strong>{{ product_code.value }}</strong></li>
      {% endfor %}

      {% if reward %}
      <li>{{ text_reward }}: <strong>{{ reward }}</strong></li>
      {% endif %}

      <li>{{ text_stock }}: <strong><span class="text-{% if stock %}success{% else %}danger{% endif %}">{{ stock_status }}</span></strong></li>
    </ul>

    {% if review_status %}
    <div class="rating">
      {% for i in 1..5 %} {% if rating < i %} <span class="fa-stack"><i class="fa-regular fa-star fa-stack-1x"></i></span> {% else %} <span class="fa-stack"><i class="fa-solid fa-star fa-stack-1x"></i><i class="fa-regular fa-star fa-stack-1x"></i></span> {% endif %} {% endfor %}
    </div>
    {% endif %}

    {% if price %}
    <ul class="list-unstyled">

      {% if not special %}
      <li>
        <h2><span class="price-new">{{ price }}</span></h2>
      </li>
      {% else %}
      <li><span class="price-old">{{ price }}</span></li>
      <li>
        <h2><span class="price-new">{{ special }}</span></h2>
      </li>
      {% endif %}

      {% if tax %}
      <li>{{ text_tax }}
        {{ tax }}
      </li>
      {% endif %}

      {% if points %}
      <li>{{ text_points }} {{ points }}</li>
      {% endif %}

      {% if discounts %}
      <li>
        <hr>
      </li>

      {% for discount in discounts %}
      <li>{{ discount.quantity }}{{ text_discount }}
        {{ discount.price }}
      </li>
      {% endfor %}

      {% endif %}
    </ul>
    {% endif %}

    <form class="mb-3">
      <div class="btn-group">
        <button type="submit" formaction="{{ wishlist_add }}" class="btn btn-light btn-lg" title="{{ button_wishlist }}"><i class="fa-solid fa-heart"></i></button>
        <button type="submit" formaction="{{ compare_add }}" class="btn btn-light btn-lg" title="{{ button_compare }}"><i class="fa-solid fa-arrow-right-arrow-left"></i></button>
      </div>
      <input type="hidden" name="product_id" value="{{ product_id }}"/>
    </form>

    <br/>
    <div id="product">
      <form id="form-product" action="{{ cart_add }}" method="post">
        {% if options %}
        <hr>
        <h3>{{ text_option }}</h3>
        <div>
          {% for option in options %}

          {% if option.type == 'select' %}


          <div class="mb-3{% if option.required %} required{% endif %}">
            <label for="input-option-{{ option.product_option_id }}" class="form-label">{{ option.name }}</label> <select name="option[{{ option.product_option_id }}]" id="input-option-{{ option.product_option_id }}" class="form-select">
            <option value="">{{ text_select }}</option>


            {% for option_value in option.option_value %}
            <option value="{{ option_value.product_option_value_id }}">{{ option_value.name }} {% if option_value.price %} ({{ option_value.price_prefix }}
              <x-currency code="{{ currency }}" amount="{{ option_value.price }}"></x-currency>
              ){% endif %}
            </option>
            {% endfor %}


          </select>
            <div id="error-option-{{ option.product_option_id }}" class="invalid-feedback"></div>
          </div>
          {% endif %}

          {% if option.type == 'radio' %}

          <div class="mb-3{% if option.required %} required{% endif %}">
            <label class="form-label">{{ option.name }}</label>
            <div id="input-option-{{ option.product_option_id }}">

              {% for option_value in option.option_value %}

              <div class="form-check">


                <input type="radio" name="option[{{ option.product_option_id }}]" value="{{ option_value.product_option_value_id }}" id="input-option-value-{{ option_value.product_option_value_id }}" class="form-check-input"/>

                <label for="input-option-value-{{ option_value.product_option_value_id }}" class="form-check-label"> {% if option_value.image %} <img src="{{ option_value.image }}" alt="{{ option_value.name }} {% if option_value.price %}{{ option_value.price_prefix }} {{ option_value.price }}{% endif %}" class="img-thumbnail"/>{% endif %} {{ option_value.name }} {% if option_value.price %} ({{ option_value.price_prefix }}
                  <x-currency code="{{ currency }}" amount="{{ option_value.price }}"></x-currency>
                  ) {% endif %} </label>


              </div>


              {% endfor %}

            </div>
            <div id="error-option-{{ option.product_option_id }}" class="invalid-feedback"></div>
          </div>

          {% endif %}

          {% if option.type == 'checkbox' %}

          <div class="mb-3{% if option.required %} required{% endif %}">
            <label class="form-label">{{ option.name }}</label>
            <div id="input-option-{{ option.product_option_id }}">

              {% for option_value in option.option_value %}
              <div class="form-check">
                <input type="checkbox" name="option[{{ option.product_option_id }}][]" value="{{ option_value.product_option_value_id }}" id="input-option-value-{{ option_value.product_option_value_id }}" class="form-check-input"/> <label for="input-option-value-{{ option_value.product_option_value_id }}" class="form-check-label"> {% if option_value.image %} <img src="{{ option_value.image }}" alt="{{ option_value.name }} {% if option_value.price %}{{ option_value.price_prefix }} {{ option_value.price }}{% endif %}" class="img-thumbnail"/>{% endif %} {{ option_value.name }} {% if option_value.price %} ({{ option_value.price_prefix }}
                <x-currency code="{{ currency }}" amount="{{ option_value.price }}"></x-currency>
                ) {% endif %}</label>
              </div>
              {% endfor %}

            </div>
            <div id="error-option-{{ option.product_option_id }}" class="invalid-feedback"></div>
          </div>

          {% endif %}

          {% if option.type == 'text' %}
          <div class="mb-3{% if option.required %} required{% endif %}">
            <label for="input-option-{{ option.product_option_id }}" class="form-label">{{ option.name }}</label>
            <input type="text" name="option[{{ option.product_option_id }}]" value="{{ option.value }}" placeholder="{{ option.name }}" id="input-option-{{ option.product_option_id }}" class="form-control"/>
            <div id="error-option-{{ option.product_option_id }}" class="invalid-feedback"></div>
          </div>
          {% endif %}

          {% if option.type == 'textarea' %}
          <div class="mb-3{% if option.required %} required{% endif %}">
            <label for="input-option-{{ option.product_option_id }}" class="form-label">{{ option.name }}</label>
            <textarea name="option[{{ option.product_option_id }}]" rows="5" placeholder="{{ option.name }}" id="input-option-{{ option.product_option_id }}" class="form-control">{{ option.value }}</textarea>
            <div id="error-option-{{ option.product_option_id }}" class="invalid-feedback"></div>
          </div>
          {% endif %}

          {% if option.type == 'file' %}
          <div class="mb-3{% if option.required %} required{% endif %}">
            <label for="button-upload-{{ option.product_option_id }}" class="form-label">{{ option.name }}</label>
            <div>
              <button type="button" id="button-upload-{{ option.product_option_id }}" data-oc-toggle="upload" data-oc-url="{{ upload }}" data-oc-target="#input-option-{{ option.product_option_id }}" data-oc-size-max="{{ config_file_max_size }}" data-oc-size-error="{{ error_upload_size }}" class="btn btn-light btn-block"><i class="fa-solid fa-upload"></i> {{ button_upload }}</button>
              <input type="hidden" name="option[{{ option.product_option_id }}]" value="" id="input-option-{{ option.product_option_id }}"/>
            </div>
            <div id="error-option-{{ option.product_option_id }}" class="invalid-feedback"></div>
          </div>
          {% endif %}

          {% if option.type == 'date' %}
          <div class="mb-3{% if option.required %} required{% endif %}">
            <label for="input-option-{{ option.product_option_id }}" class="form-label">{{ option.name }}</label>
            <input type="date" name="option[{{ option.product_option_id }}]" value="{{ option.value }}" id="input-option-{{ option.product_option_id }}" class="form-control"/>
            <div id="error-option-{{ option.product_option_id }}" class="invalid-feedback"></div>
          </div>
          {% endif %}

          {% if option.type == 'time' %}
          <div class="mb-3{% if option.required %} required{% endif %}">
            <label for="input-option-{{ option.product_option_id }}" class="form-label">{{ option.name }}</label>
            <input type="time" name="option[{{ option.product_option_id }}]" value="{{ option.value }}" id="input-option-{{ option.product_option_id }}" class="form-control"/>
            <div id="error-option-{{ option.product_option_id }}" class="invalid-feedback"></div>
          </div>
          {% endif %}

          {% if option.type == 'datetime' %}
          <div class="mb-3{% if option.required %} required{% endif %}">
            <label for="input-option-{{ option.product_option_id }}" class="form-label">{{ option.name }}</label>
            <input type="datetime-local" name="option[{{ option.product_option_id }}]" value="{{ option.value }}" id="input-option-{{ option.product_option_id }}" class="form-control"/>
            <div id="error-option-{{ option.product_option_id }}" class="invalid-feedback"></div>
          </div>
          {% endif %}

          {% endfor %}
        </div>
        {% endif %}

        {% if subscription_plans %}
        <hr/>
        <h3>{{ text_subscription }}</h3>
        <div class="mb-3">
          <select name="subscription_plan_id" id="input-subscription" data-on="change:onChange" class="form-select" required>
            <option value="">{{ text_select }}</option>

            {% for subscription_plan in subscription_plans %}



            "text_subscription_duration": "%s every %d %s(s) for %d payment(s)",

            "text_subscription_cancel": "%s every %d %s(s) until canceled",


            {% if subscription_plan.duration %}

            <option value="{{ subscription_plan.subscription_plan_id }}">{{ subscription_plan.description }}</option>

            {% else %}

            <option value="{{ subscription_plan.subscription_plan_id }}">{{ subscription_plan.description }}</option>
            text_subscription_cancel

            {% endif %}


            {% endfor %}

          </select>

          {% for subscription_plan in subscription_plans %}
          <div id="subscription-description-{{ subscription_plan.subscription_plan_id }}" class="form-text subscription d-none">{{ subscription_plan.description }}</div>
          {% endfor %}

          <div id="error-subscription" class="invalid-feedback"></div>
        </div>
        {% endif %}

        <div class="mb-3">
          <div class="input-group">
            <div class="input-group-text">{{ entry_qty }}</div>
            <input type="text" name="quantity" value="{{ minimum }}" size="2" id="input-quantity" data-bind="quantity" class="form-control"/>
            <button type="submit" id="button-cart" data-bind="button_cart" class="btn btn-primary btn-lg btn-block">{{ button_cart }}</button>
          </div>
          <input type="hidden" name="product_id" value="{{ product_id }}" id="input-product-id"/>
          <div id="error-quantity" class="form-text"></div>
        </div>

        {% if minimum > 1 %}
        <div class="alert alert-warning"><i class="fa-solid fa-circle-info"></i> {{ text_minimum }}</div>
        {% endif %}
      </form>
    </div>
  </div>
    </div>
</div>

<section class="trust-strip p-3 p-lg-4 mb-4" aria-label="Purchase confidence">
  <div class="row g-3 row-cols-1 row-cols-sm-2 row-cols-lg-5">
    <div class="col trust-item"><i class="fa-solid fa-box-open"></i><div><strong>Discreet Packaging</strong><span>Plain outer parcel</span></div></div>
    <div class="col trust-item"><i class="fa-solid fa-file-invoice"></i><div><strong>Private Billing</strong><span>Clean checkout flow</span></div></div>
    <div class="col trust-item"><i class="fa-solid fa-lock"></i><div><strong>Secure Checkout</strong><span>Encrypted payment</span></div></div>
    <div class="col trust-item"><i class="fa-solid fa-certificate"></i><div><strong>Body-safe Focus</strong><span>Check material details</span></div></div>
    <div class="col trust-item"><i class="fa-solid fa-truck-fast"></i><div><strong>Fast Shipping</strong><span>Clear delivery info</span></div></div>
  </div>
</section>

<section class="wellness-section mb-4">
  <span class="wellness-kicker mb-2">Product guidance</span>
  <h2 class="h4 fw-bold mb-3">Details for confident, private shopping</h2>
  {% set wellness_specs = [] %}
  {% for attribute_group in attribute_groups %}
    {% for attribute in attribute_group.attribute %}
      {% set wellness_specs = wellness_specs|merge([{'name': attribute.name, 'text': attribute.text}]) %}
    {% endfor %}
  {% endfor %}
  <div class="spec-grid">
    {% if wellness_specs %}
      {% for spec in wellness_specs %}<div class="spec-tile"><small>{{ spec.name }}</small><strong>{{ spec.text }}</strong></div>{% endfor %}
    {% else %}
      <div class="spec-tile"><small>Materials</small><strong>See product description / label</strong></div>
      <div class="spec-tile"><small>Size & fit</small><strong>Check options and measurements</strong></div>
      <div class="spec-tile"><small>Waterproof</small><strong>Use only as specified</strong></div>
      <div class="spec-tile"><small>Charging / care</small><strong>Follow included instructions</strong></div>
      <div class="spec-tile"><small>Noise</small><strong>Choose Quiet & Discreet items if needed</strong></div>
      <div class="spec-tile"><small>In the box</small><strong>Product, packaging and care notes when provided</strong></div>
    {% endif %}
  </div>
</section>

<ul class="nav nav-tabs">
  <li class="nav-item"><a href="#tab-description" data-bs-toggle="tab" class="nav-link active">{{ tab_description }}</a></li>
  {% if attribute_groups %}
  <li class="nav-item"><a href="#tab-specification" data-bs-toggle="tab" class="nav-link">{{ tab_attribute }}</a></li>
  {% endif %} {% if review_status %}
  <li class="nav-item"><a href="#tab-review" data-bs-toggle="tab" class="nav-link">{{ tab_review }}</a></li>
  {% endif %}
</ul>
<div class="tab-content">
  <div id="tab-description" class="tab-pane fade show active mb-4 wellness-section border-top-0 rounded-top-0">
    <h2 class="h4 fw-bold">Description & safe-use notes</h2>
    {{ description }}
    <div class="row g-3 mt-3">
      <div class="col-md-6"><h3 class="h6 fw-bold">How to use</h3><p class="text-muted small">Read the product label before use. Start gently, stop if discomfort occurs, and keep products clean and dry as instructed.</p></div>
      <div class="col-md-6"><h3 class="h6 fw-bold">Cleaning & storage</h3><p class="text-muted small">Clean according to material guidance, dry fully before storage, and store privately away from heat and moisture.</p></div>
      <div class="col-md-6"><h3 class="h6 fw-bold">Privacy shipping</h3><p class="text-muted small">Orders are positioned for discreet packing and private delivery expectations.</p></div>
      <div class="col-md-6"><h3 class="h6 fw-bold">Returns</h3><p class="text-muted small">For hygiene reasons, intimate products may have limited returns once opened. Check policy before purchase.</p></div>
    </div> {% if tags %}
    <p><strong>{{ text_tags }}</strong> {% for tag in tags %} <a href="{{ tag.href }}">{{ tag.tag }}</a>{% if not loop.last %},{% endif %} {% endfor %}
    </p>
    {% endif %}
  </div>
  {% if attribute_groups %}
  <div id="tab-specification" class="tab-pane fade">
    <div class="table-responsive">
      <table class="table table-bordered">
        {% for attribute_group in attribute_groups %}
        <thead>
          <tr>
            <td colspan="2"><strong>{{ attribute_group.name }}</strong></td>
          </tr>
        </thead>
        <tbody>
          {% for attribute in attribute_group.attribute %}
          <tr>
            <td>{{ attribute.name }}</td>
            <td>{{ attribute.text }}</td>
          </tr>
          {% endfor %}
        </tbody>
        {% endfor %}
      </table>
    </div>
  </div>
  {% endif %} {% if review_status %}
  <div id="tab-review" class="tab-pane fade mb-4">{{ review }}</div>
  {% endif %}
</div>
<section class="wellness-section mb-4">
  <span class="wellness-kicker mb-2">FAQ</span>
  <div class="accordion" id="productFaq">
    <div class="accordion-item"><h3 class="accordion-header"><button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faqOne">Will the package be discreet?</button></h3><div id="faqOne" class="accordion-collapse collapse show" data-bs-parent="#productFaq"><div class="accordion-body text-muted">The store is designed around discreet packaging and private delivery expectations, without explicit wording on the public-facing parcel.</div></div></div>
    <div class="accordion-item"><h3 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faqTwo">How do I choose the right product?</button></h3><div id="faqTwo" class="accordion-collapse collapse" data-bs-parent="#productFaq"><div class="accordion-body text-muted">Use the scenario categories such as Beginner Friendly, For Couples, Solo Wellness, Quiet & Discreet, Waterproof, and Lubricants & Care.</div></div></div>
    <div class="accordion-item"><h3 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faqThree">How should intimate products be cleaned?</button></h3><div id="faqThree" class="accordion-collapse collapse" data-bs-parent="#productFaq"><div class="accordion-body text-muted">Follow the product-specific material and care instructions. Clean before and after use, dry fully, and store in a clean private place.</div></div></div>
  </div>
</section>
{{ related }}
{% if price %}<div class="sticky-atc"><div><strong>{% if special %}{{ special }}{% else %}{{ price }}{% endif %}</strong><div class="age-note">Discreet checkout · 18+</div></div><button type="button" class="btn btn-primary" onclick="document.getElementById('button-cart')?.click()">Add to Cart</button></div>{% endif %}

<script>
(function () {
  const form = document.getElementById('form-product');
  if (!form) return;

  function showMessage(type, message) {
    let box = document.getElementById('product-alert');
    if (!box) {
      box = document.createElement('div');
      box.id = 'product-alert';
      form.parentNode.insertBefore(box, form);
    }
    box.innerHTML = '<div class="alert alert-' + type + ' alert-dismissible"><i class="fa-solid fa-circle-' + (type === 'danger' ? 'exclamation' : 'check') + '"></i> ' + message + ' <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
  }

  function clearErrors() {
    form.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));
    form.querySelectorAll('.invalid-feedback,.form-text').forEach(el => {
      if (el.id && el.id.startsWith('error-')) el.textContent = '';
    });
  }

  form.addEventListener('submit', async function (event) {
    event.preventDefault();
    clearErrors();
    const button = document.getElementById('button-cart');
    const original = button ? button.innerHTML : '';
    if (button) {
      button.disabled = true;
      button.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Adding...';
    }

    try {
      const response = await fetch(form.action.replaceAll('&amp;', '&'), {
        method: 'POST',
        body: new FormData(form),
        credentials: 'same-origin'
      });
      const json = await response.json();

      if (json.redirect) {
        window.location = json.redirect;
        return;
      }

      if (json.error) {
        if (json.error.warning) showMessage('danger', json.error.warning);
        Object.keys(json.error).forEach(function (key) {
          if (key === 'warning') return;
          const id = key.replaceAll('_', '-');
          const input = document.getElementById('input-' + id);
          const error = document.getElementById('error-' + id);
          if (input) input.classList.add('is-invalid');
          if (error) error.textContent = json.error[key];
        });
        if (!json.error.warning) showMessage('danger', 'Please check the product options and try again.');
        return;
      }

      if (json.success) {
        showMessage('success', json.success);
      }
    } catch (error) {
      showMessage('danger', 'Could not add this product to cart. Please refresh and try again.');
      // Keep customer-facing errors calm; detailed diagnostics belong in server logs.
    } finally {
      if (button) {
        button.disabled = false;
        button.innerHTML = original;
      }
    }
  });
})();
</script>

</main>
{{ footer }}
