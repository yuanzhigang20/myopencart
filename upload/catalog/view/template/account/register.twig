{{ header }}
<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-10 col-xl-9">
      <div class="text-center mb-4">
        <span class="badge text-bg-primary mb-2">New Customer</span>
        <h1 class="fw-bold mb-2">{{ heading_title }}</h1>
        <p class="text-muted mb-0">{{ text_account_already|raw }}</p>
      </div>

      <div id="alert"></div>

      <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-4 p-lg-5">
          <form id="form-register" action="{{ save }}" method="post" novalidate>
            {% if customer_groups|length > 1 %}
              <div class="mb-4">
                <label for="input-customer-group" class="form-label fw-semibold">{{ entry_customer_group }}</label>
                <select name="customer_group_id" id="input-customer-group" class="form-select form-select-lg" required>
                  {% for customer_group in customer_groups %}
                    <option value="{{ customer_group.customer_group_id }}"{% if customer_group.customer_group_id == customer_group_id %} selected{% endif %}>{{ customer_group.name }}</option>
                  {% endfor %}
                </select>
                <div id="error-customer-group" class="invalid-feedback"></div>
              </div>
            {% else %}
              <input type="hidden" name="customer_group_id" value="{{ customer_group_id }}">
            {% endif %}

            <div class="row g-4">
              <div class="col-12">
                <h2 class="h5 fw-bold border-bottom pb-2 mb-0"><i class="fa-solid fa-user me-2 text-primary"></i>{{ text_your_details }}</h2>
              </div>

              <div class="col-md-6">
                <label for="input-firstname" class="form-label">{{ entry_firstname }}</label>
                <input type="text" name="firstname" value="" placeholder="{{ entry_firstname }}" id="input-firstname" class="form-control form-control-lg" autocomplete="given-name" required>
                <div id="error-firstname" class="invalid-feedback"></div>
              </div>

              <div class="col-md-6">
                <label for="input-lastname" class="form-label">{{ entry_lastname }}</label>
                <input type="text" name="lastname" value="" placeholder="{{ entry_lastname }}" id="input-lastname" class="form-control form-control-lg" autocomplete="family-name" required>
                <div id="error-lastname" class="invalid-feedback"></div>
              </div>

              <div class="col-md-6">
                <label for="input-email" class="form-label">{{ entry_email }}</label>
                <input type="email" name="email" value="" placeholder="{{ entry_email }}" id="input-email" class="form-control form-control-lg" autocomplete="email" required>
                <div id="error-email" class="invalid-feedback"></div>
              </div>

              {% if config_telephone_status %}
                <div class="col-md-6">
                  <label for="input-telephone" class="form-label">{{ entry_telephone }}</label>
                  <input type="tel" name="telephone" value="" placeholder="{{ entry_telephone }}" id="input-telephone" class="form-control form-control-lg" autocomplete="tel"{% if config_telephone_required %} required{% endif %}>
                  <div id="error-telephone" class="invalid-feedback"></div>
                </div>
              {% else %}
                <input type="hidden" name="telephone" value="">
              {% endif %}

              {% if custom_fields %}
                {% for custom_field in custom_fields %}
                  {% if custom_field.type == 'text' %}
                    <div class="col-md-6 custom-field custom-field-{{ custom_field.custom_field_id }}">
                      <label for="input-custom-field-{{ custom_field.custom_field_id }}" class="form-label">{{ custom_field.name }}</label>
                      <input type="text" name="custom_field[{{ custom_field.custom_field_id }}]" value="{{ custom_field.value }}" placeholder="{{ custom_field.name }}" id="input-custom-field-{{ custom_field.custom_field_id }}" class="form-control form-control-lg">
                      <div id="error-custom-field-{{ custom_field.custom_field_id }}" class="invalid-feedback"></div>
                    </div>
                  {% elseif custom_field.type == 'textarea' %}
                    <div class="col-12 custom-field custom-field-{{ custom_field.custom_field_id }}">
                      <label for="input-custom-field-{{ custom_field.custom_field_id }}" class="form-label">{{ custom_field.name }}</label>
                      <textarea name="custom_field[{{ custom_field.custom_field_id }}]" rows="4" placeholder="{{ custom_field.name }}" id="input-custom-field-{{ custom_field.custom_field_id }}" class="form-control">{{ custom_field.value }}</textarea>
                      <div id="error-custom-field-{{ custom_field.custom_field_id }}" class="invalid-feedback"></div>
                    </div>
                  {% elseif custom_field.type == 'select' %}
                    <div class="col-md-6 custom-field custom-field-{{ custom_field.custom_field_id }}">
                      <label for="input-custom-field-{{ custom_field.custom_field_id }}" class="form-label">{{ custom_field.name }}</label>
                      <select name="custom_field[{{ custom_field.custom_field_id }}]" id="input-custom-field-{{ custom_field.custom_field_id }}" class="form-select form-select-lg">
                        <option value="">{{ text_select }}</option>
                        {% for custom_field_value in custom_field.custom_field_value %}
                          <option value="{{ custom_field_value.custom_field_value_id }}">{{ custom_field_value.name }}</option>
                        {% endfor %}
                      </select>
                      <div id="error-custom-field-{{ custom_field.custom_field_id }}" class="invalid-feedback"></div>
                    </div>
                  {% endif %}
                {% endfor %}
              {% endif %}

              <div class="col-12 mt-5">
                <h2 class="h5 fw-bold border-bottom pb-2 mb-0"><i class="fa-solid fa-lock me-2 text-primary"></i>{{ text_your_password }}</h2>
              </div>

              <div class="col-md-6">
                <label for="input-password" class="form-label">{{ entry_password }}</label>
                <input type="password" name="password" value="" placeholder="{{ entry_password }}" id="input-password" class="form-control form-control-lg" autocomplete="new-password" required>
                <div id="error-password" class="invalid-feedback"></div>
              </div>

              <div class="col-12 mt-5">
                <h2 class="h5 fw-bold border-bottom pb-2 mb-0"><i class="fa-solid fa-envelope me-2 text-primary"></i>{{ text_newsletter }}</h2>
              </div>

              <div class="col-12">
                <div class="form-check form-switch fs-5">
                  <input type="hidden" name="newsletter" value="0">
                  <input class="form-check-input" type="checkbox" role="switch" name="newsletter" value="1" id="input-newsletter">
                  <label class="form-check-label" for="input-newsletter">{{ entry_newsletter }}</label>
                </div>
              </div>

              {% if captcha %}
                <div class="col-12">{{ captcha }}</div>
              {% endif %}

              {% if text_agree %}
                <div class="col-12">
                  <div class="form-check p-3 rounded-3 bg-light border">
                    <input class="form-check-input" type="checkbox" name="agree" value="1" id="input-agree" required>
                    <label class="form-check-label" for="input-agree">{{ text_agree|raw }}</label>
                  </div>
                </div>
              {% else %}
                <input type="hidden" name="agree" value="1">
              {% endif %}

              <div class="col-12 d-flex flex-column flex-sm-row gap-3 justify-content-between align-items-sm-center pt-3">
                <a href="{{ login }}" class="text-decoration-none"><i class="fa-solid fa-arrow-left me-1"></i> Back to login</a>
                <button type="submit" id="button-continue" class="btn btn-primary btn-lg px-5">{{ button_continue }}</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</main>
<script>
(function () {
  const form = document.getElementById('form-register');
  const alertBox = document.getElementById('alert');
  if (!form || !alertBox) return;

  function clearErrors() {
    alertBox.innerHTML = '';
    form.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));
    form.querySelectorAll('.invalid-feedback').forEach(el => el.textContent = '');
  }

  function showAlert(type, message) {
    alertBox.innerHTML = '<div class="alert alert-' + type + ' alert-dismissible"><i class="fa-solid fa-circle-' + (type === 'danger' ? 'exclamation' : 'check') + '"></i> ' + message + ' <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
    alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function fieldId(key) {
    return 'input-' + key.replaceAll('_', '-');
  }

  form.addEventListener('submit', async function (event) {
    event.preventDefault();
    clearErrors();

    const button = document.getElementById('button-continue');
    const original = button.innerHTML;
    button.disabled = true;
    button.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Creating account...';

    try {
      const response = await fetch(form.action.replaceAll('&amp;', '&'), {
        method: 'POST',
        body: new FormData(form),
        credentials: 'same-origin'
      });
      const json = await response.json();

      if (json.redirect) {
        window.location = json.redirect;
        return;
      }

      if (json.error) {
        if (json.error.warning) {
          showAlert('danger', json.error.warning);
        } else if (typeof json.error === 'string') {
          showAlert('danger', json.error);
        } else {
          showAlert('danger', 'Please check the highlighted fields and try again.');
        }

        Object.keys(json.error).forEach(function (key) {
          if (key === 'warning') return;
          const input = document.getElementById(fieldId(key));
          const error = document.getElementById('error-' + key.replaceAll('_', '-'));
          if (input) input.classList.add('is-invalid');
          if (error) error.textContent = json.error[key];
        });
        return;
      }

      showAlert('success', 'Account created successfully. Redirecting...');
    } catch (error) {
      showAlert('danger', 'Registration request failed. Please refresh and try again.');
      console.error(error);
    } finally {
      button.disabled = false;
      button.innerHTML = original;
    }
  });
})();
</script>
{{ footer }}
