{{ header }}
<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-xl-10">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-lg-5">
          <h1 class="fw-bold mb-4">{{ text_address }}</h1>
          <form id="form-address" action="{{ save }}" method="post">
            <div class="row g-3">
              <div class="col-md-6">
                <label for="input-firstname" class="form-label">{{ entry_firstname }}</label>
                <input type="text" name="firstname" value="{{ firstname }}" placeholder="{{ entry_firstname }}" id="input-firstname" class="form-control" required>
                <div id="error-firstname" class="invalid-feedback d-block"></div>
              </div>
              <div class="col-md-6">
                <label for="input-lastname" class="form-label">{{ entry_lastname }}</label>
                <input type="text" name="lastname" value="{{ lastname }}" placeholder="{{ entry_lastname }}" id="input-lastname" class="form-control" required>
                <div id="error-lastname" class="invalid-feedback d-block"></div>
              </div>
              <div class="col-12">
                <label for="input-company" class="form-label">{{ entry_company }}</label>
                <input type="text" name="company" value="{{ company }}" placeholder="{{ entry_company }}" id="input-company" class="form-control">
              </div>
              <div class="col-12">
                <label for="input-address-1" class="form-label">{{ entry_address_1 }}</label>
                <input type="text" name="address_1" value="{{ address_1 }}" placeholder="{{ entry_address_1 }}" id="input-address-1" class="form-control" required>
                <div id="error-address-1" class="invalid-feedback d-block"></div>
              </div>
              <div class="col-12">
                <label for="input-address-2" class="form-label">{{ entry_address_2 }}</label>
                <input type="text" name="address_2" value="{{ address_2 }}" placeholder="{{ entry_address_2 }}" id="input-address-2" class="form-control">
              </div>
              <div class="col-md-6">
                <label for="input-city" class="form-label">{{ entry_city }}</label>
                <input type="text" name="city" value="{{ city }}" placeholder="{{ entry_city }}" id="input-city" class="form-control" required>
                <div id="error-city" class="invalid-feedback d-block"></div>
              </div>
              <div class="col-md-6">
                <label for="input-postcode" class="form-label">{{ entry_postcode }}</label>
                <input type="text" name="postcode" value="{{ postcode }}" placeholder="{{ entry_postcode }}" id="input-postcode" class="form-control" required>
                <div id="error-postcode" class="invalid-feedback d-block"></div>
              </div>
              <div class="col-12">
                <label class="form-label">{{ entry_country }} / {{ entry_zone }}</label>
                <div class="form-control bg-light">Default store region</div>
                <input type="hidden" name="country_id" value="{{ country_id ?: 222 }}">
                <input type="hidden" name="zone_id" value="{{ zone_id ?: 3563 }}">
                <div id="error-country" class="invalid-feedback d-block"></div>
                <div id="error-zone" class="invalid-feedback d-block"></div>
              </div>
              <div class="col-12">
                <div class="form-check">
                  <input type="checkbox" name="default" value="1" id="input-default" class="form-check-input" {% if default %}checked{% endif %}>
                  <label for="input-default" class="form-check-label">{{ entry_default }}</label>
                </div>
              </div>
            </div>
            <div id="address-form-alert" class="mt-3"></div>
            <div class="d-flex justify-content-between mt-4">
              <a href="{{ back }}" class="btn btn-light">{{ button_back }}</a>
              <button type="submit" class="btn btn-primary">{{ button_continue }}</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</main>
<script>
(function(){
  const form = document.getElementById('form-address');
  if (!form) return;
  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    form.querySelectorAll('.invalid-feedback').forEach(el => el.textContent = '');
    const alert = document.getElementById('address-form-alert');
    if (alert) alert.innerHTML = '';
    const response = await fetch(form.action, {method: 'POST', body: new FormData(form), credentials: 'same-origin'});
    const json = await response.json();
    if (json.redirect) { location.href = json.redirect; return; }
    if (json.error) {
      Object.entries(json.error).forEach(([key, message]) => {
        const el = document.getElementById('error-' + key.replace('_', '-'));
        if (el) el.textContent = message;
      });
      if (alert) alert.innerHTML = '<div class="alert alert-danger">Please fix the highlighted fields.</div>';
      return;
    }
    location.href = '{{ back }}';
  });
})();
</script>
{{ footer }}
