<h1>{{ heading_title }}</h1>
<div class="row">
  <div class="col-sm-6">
    <ul>
      {% for category_1 in categories %}
        <li><a href="{{ category_1.href }}">{{ category_1.name }}</a>
          {% if category_1.children %}
            <ul>
              {% for category_2 in category_1.children %}
                <li><a href="{{ category_2.href }}">{{ category_2.name }}</a>
                  {% if category_2.children %}
                    <ul>
                      {% for category_3 in category_2.children %}
                        <li><a href="{{ category_3.href }}">{{ category_3.name }}</a></li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="col-sm-6">
    <ul>
      <li><a href="product/search">{{ text_search }}</a></li>
      <li><a href="product/special">{{ text_special }}</a></li>
      <li><a href="account/account">{{ text_account }}</a>
        <ul>
          <li><a href="account/edit">{{ text_edit }}</a></li>
          <li><a href="account/password">{{ text_password }}</a></li>
          <li><a href="account/address">{{ text_address }}</a></li>
          <li><a href="account/history">{{ text_history }}</a></li>
          <li><a href="account/download">{{ text_download }}</a></li>
        </ul>
      </li>
      <li><a href="checkout/cart">{{ text_cart }}</a></li>
      <li><a href="checkout/checkout">{{ text_checkout }}</a></li>
      <li>{{ text_information }}
        <ul>
          {% for information in informations %}
            <li><a href="information/information-{{ information.information_id }}">{{ information.title }}</a></li>
          {% endfor %}
          <li><a href="information/contact">{{ text_contact }}</a></li>
        </ul>
      </li>
    </ul>
  </div>
</div>
