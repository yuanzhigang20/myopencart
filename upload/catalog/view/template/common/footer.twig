<footer class="footer mt-auto py-5">
  <div class="container">
    <div class="row g-4">
      <div class="col-md-4"><h5>{{ text_information }}</h5><p class="mb-0">Demo OpenCart store for testing products, cart and checkout flow.</p></div>
      <div class="col-md-4"><h5>{{ text_service }}</h5><ul class="list-unstyled"><li><a href="{{ contact }}">{{ text_contact }}</a></li><li><a href="{{ sitemap }}">{{ text_sitemap }}</a></li></ul></div>
      <div class="col-md-4"><h5>{{ text_account }}</h5><ul class="list-unstyled"><li><a href="{{ account }}">{{ text_account }}</a></li><li><a href="{{ order }}">{{ text_order }}</a></li><li><a href="{{ wishlist }}">{{ text_wishlist }}</a></li></ul></div>
    </div>
    <hr class="border-secondary"><div class="small">{{ powered }}</div>
  </div>
</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
(function () {
  function showAlert(type, html) {
    var holder = document.getElementById('alert');
    if (!holder) {
      holder = document.createElement('div');
      holder.id = 'alert';
      holder.className = 'position-fixed top-0 start-50 translate-middle-x p-3';
      holder.style.cssText = 'z-index:1080;max-width:min(92vw,720px);';
      document.body.prepend(holder);
    }

    holder.innerHTML = '<div class="alert alert-' + type + ' alert-dismissible shadow-sm" role="alert">' + html + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>';

    window.setTimeout(function () {
      var alert = holder.querySelector('.alert');
      if (alert) {
        try {
          bootstrap.Alert.getOrCreateInstance(alert).close();
        } catch (e) {
          alert.remove();
        }
      }
    }, 4500);
  }

  function setButtonLoading(button, loading) {
    if (!button) return;
    if (loading) {
      button.dataset.originalHtml = button.innerHTML;
      button.disabled = true;
      button.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i>';
    } else {
      button.disabled = false;
      if (button.dataset.originalHtml) button.innerHTML = button.dataset.originalHtml;
    }
  }

  function refreshCartTargets(loadUrl, targetSelector, cartLoadUrl) {
    var jobs = [];

    if (loadUrl && targetSelector) {
      var target = document.querySelector(targetSelector);
      if (target) {
        jobs.push(fetch(loadUrl.replaceAll('&amp;', '&'), { credentials: 'same-origin' }).then(function (response) { return response.text(); }).then(function (html) { target.innerHTML = html; }));
      }
    }

    var cartUrl = cartLoadUrl || ((targetSelector === '#cart') ? loadUrl : '');
    if (cartUrl && targetSelector !== '#cart') {
      var cart = document.querySelector('#cart');
      if (cart) {
        jobs.push(fetch(cartUrl.replaceAll('&amp;', '&'), { credentials: 'same-origin' }).then(function (response) { return response.text(); }).then(function (html) { cart.innerHTML = html; }));
      }
    }

    return Promise.all(jobs);
  }

  document.addEventListener('click', async function (event) {
    var link = event.target.closest('a[data-oc-toggle="ajax"]');
    if (!link) return;

    event.preventDefault();

    var loadUrl = link.getAttribute('data-oc-load');
    var targetSelector = link.getAttribute('data-oc-target');
    var cartLoadUrl = link.getAttribute('data-oc-cart-load');

    try {
      link.classList.add('disabled');
      var response = await fetch(link.href.replaceAll('&amp;', '&'), {
        method: 'GET',
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        credentials: 'same-origin'
      });
      var json = await response.json();

      document.querySelectorAll('.alert-dismissible').forEach(function (node) { node.remove(); });

      if (json.redirect && loadUrl && targetSelector) {
        await refreshCartTargets(loadUrl, targetSelector, cartLoadUrl);
        return;
      }

      if (json.redirect) {
        window.location.href = json.redirect;
        return;
      }

      if (json.error) {
        var message = typeof json.error === 'string' ? json.error : (json.error.warning || Object.values(json.error)[0]);
        showAlert('danger', '<i class="fa-solid fa-circle-exclamation"></i> ' + message);
      }

      if (json.success) {
        showAlert('success', '<i class="fa-solid fa-circle-check"></i> ' + json.success);
      }

      await refreshCartTargets(loadUrl, targetSelector, cartLoadUrl);
    } catch (error) {
      showAlert('danger', '<i class="fa-solid fa-circle-exclamation"></i> Cart update failed. Please try again.');
      console.error(error);
    } finally {
      link.classList.remove('disabled');
    }
  }, true);

  document.addEventListener('submit', async function (event) {
    var form = event.target;
    var button = event.submitter || form.querySelector('button[type="submit"]');

    if (!form || form.getAttribute('data-oc-toggle') !== 'ajax') return;

    event.preventDefault();

    var action = (button && button.getAttribute('formaction')) || form.getAttribute('action');
    var method = (button && button.getAttribute('formmethod')) || form.getAttribute('method') || 'post';
    var loadUrl = form.getAttribute('data-oc-load');
    var targetSelector = form.getAttribute('data-oc-target');
    var cartLoadUrl = form.getAttribute('data-oc-cart-load');

    try {
      setButtonLoading(button, true);

      var response = await fetch(action.replaceAll('&amp;', '&'), {
        method: method.toUpperCase(),
        headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8', 'X-Requested-With': 'XMLHttpRequest' },
        body: new URLSearchParams(new FormData(form)).toString(),
        credentials: 'same-origin'
      });

      var json = await response.json();

      document.querySelectorAll('.alert-dismissible').forEach(function (node) { node.remove(); });

      if (json.redirect) {
        window.location.href = json.redirect;
        return;
      }

      if (json.error) {
        var message = typeof json.error === 'string' ? json.error : (json.error.warning || Object.values(json.error)[0]);
        showAlert('danger', '<i class="fa-solid fa-circle-exclamation"></i> ' + message);
      }

      if (json.success) {
        showAlert('success', '<i class="fa-solid fa-circle-check"></i> ' + json.success);

        if (loadUrl && targetSelector) {
          await refreshCartTargets(loadUrl, targetSelector, cartLoadUrl);
        }
      }
    } catch (error) {
      showAlert('danger', '<i class="fa-solid fa-circle-exclamation"></i> Add to cart failed. Please try again.');
      console.error(error);
    } finally {
      setButtonLoading(button, false);
    }
  }, true);
})();
</script>
{% for script in scripts %}<script src="{{ script.href }}"></script>{% endfor %}
</body>
</html>
