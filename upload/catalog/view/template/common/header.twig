<!doctype html>
<html dir="{{ direction }}" lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <base href="{{ base }}">
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  {% if keywords %}<meta name="keywords" content="{{ keywords }}">{% endif %}
  <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1">
  <meta property="og:site_name" content="{{ name }}">
  <meta property="og:title" content="{{ title }}">
  {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
  {% if not has_og_type %}<meta property="og:type" content="website">{% endif %}
  {% if not has_og_url %}<meta property="og:url" content="{{ current_url }}">{% endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  {% if description %}<meta name="twitter:description" content="{{ description }}">{% endif %}
  {% for link in links %}<link href="{{ link.href }}" rel="{{ link.rel }}">{% endfor %}
  {% for meta in metas %}<meta{% for key, value in meta %} {{ key }}="{{ value }}"{% endfor %}>{% endfor %}
  {% if icon %}<link rel="icon" href="{{ icon }}">{% endif %}
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
  <style>
    :root{--lv-ivory:#fbf7f1;--lv-cream:#f6eee6;--lv-beige:#eadfd6;--lv-rose:#c9aaa2;--lv-rose-deep:#9d766e;--lv-cocoa:#33231d;--lv-cocoa-2:#4a352d;--lv-ink:#241b17;--lv-muted:#74655f;--lv-line:#e5d8cf;--lv-card:#fffdf9;--lv-shadow:0 18px 46px rgba(51,35,29,.08);--lv-radius:28px}html{scroll-behavior:smooth;max-width:100%;overflow-x:hidden}body{max-width:100%;overflow-x:hidden;background:var(--lv-ivory);color:var(--lv-ink);font-family:Inter,ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif;letter-spacing:.005em}.container{max-width:1320px}.privacy-bar{background:var(--lv-cocoa);color:#f7eee7;font-size:.84rem;letter-spacing:.04em}.privacy-bar .container{display:flex;justify-content:center;gap:1.1rem;flex-wrap:wrap;padding:.52rem .75rem}.navbar{background:rgba(251,247,241,.96)!important;backdrop-filter:blur(18px);border-color:var(--lv-line)!important}.navbar-brand{font-weight:900;letter-spacing:.11em;text-transform:uppercase;color:var(--lv-cocoa)!important}.nav-link{color:var(--lv-muted)!important;font-weight:700}.nav-link:hover,.nav-link:focus{color:var(--lv-cocoa)!important}.dropdown-menu{border-color:var(--lv-line);border-radius:18px;box-shadow:var(--lv-shadow)}.btn{border-radius:999px;font-weight:800;min-height:44px;display:inline-flex;align-items:center;justify-content:center;gap:.45rem;white-space:nowrap}.btn-primary{--bs-btn-bg:var(--lv-cocoa);--bs-btn-border-color:var(--lv-cocoa);--bs-btn-hover-bg:#201611;--bs-btn-hover-border-color:#201611;--bs-btn-active-bg:#201611;--bs-btn-active-border-color:#201611}.btn-outline-primary{--bs-btn-color:var(--lv-cocoa);--bs-btn-border-color:rgba(51,35,29,.34);--bs-btn-hover-bg:var(--lv-cocoa);--bs-btn-hover-border-color:var(--lv-cocoa)}.btn-light{background:#fff;border-color:var(--lv-line);color:var(--lv-cocoa)}.form-control,.form-select{border-radius:16px;border-color:var(--lv-line);min-height:44px}.form-control:focus,.form-select:focus{border-color:var(--lv-rose);box-shadow:0 0 0 .2rem rgba(201,170,162,.24)}.home-commerce{background:radial-gradient(circle at 8% 8%,rgba(201,170,162,.23),transparent 26%),var(--lv-ivory)}.home-section{margin:4.4rem auto}.section-head{display:flex;align-items:flex-end;justify-content:space-between;gap:1rem;margin-bottom:1.35rem}.section-kicker,.hero-kicker,.wellness-pill{display:inline-flex;align-items:center;gap:.45rem;border:1px solid var(--lv-line);background:rgba(255,255,255,.7);color:var(--lv-cocoa);border-radius:999px;padding:.42rem .75rem;font-size:.76rem;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.section-head h2{font-size:clamp(1.7rem,2.6vw,2.55rem);font-weight:900;letter-spacing:-.035em;color:var(--lv-cocoa)}.home-hero{padding:2rem 0 1rem}.hero-grid{display:grid;grid-template-columns:minmax(0,1.05fr) minmax(390px,.95fr);gap:1.25rem;align-items:stretch}.hero-copy-panel{border:1px solid var(--lv-line);border-radius:34px;background:linear-gradient(135deg,#fffaf4 0%,#f3e7df 100%);padding:clamp(1.35rem,3.8vw,3.3rem);box-shadow:var(--lv-shadow);display:flex;flex-direction:column;justify-content:center;min-height:560px}.hero-copy-panel h1{max-width:780px;font-size:clamp(2.55rem,5vw,5.1rem);line-height:.96;font-weight:950;letter-spacing:-.06em;color:var(--lv-cocoa);margin:.9rem 0 1rem}.hero-subtitle{max-width:680px;color:var(--lv-muted);font-size:1.15rem;line-height:1.72}.hero-actions{display:flex;flex-wrap:wrap;gap:.75rem;margin:1.4rem 0}.hero-trust-points{display:flex;flex-wrap:wrap;gap:.6rem 1rem;color:var(--lv-cocoa-2);font-weight:800}.hero-trust-points span{display:inline-flex;align-items:center;gap:.4rem}.hero-visual-panel{border:1px solid var(--lv-line);border-radius:34px;background:linear-gradient(160deg,#fffdf9 0%,#efe1da 58%,#d9c2b8 100%);box-shadow:var(--lv-shadow);padding:1.1rem;display:grid;grid-template-rows:1fr auto;gap:1rem;min-height:560px;overflow:hidden}.brand-visual{position:relative;min-height:330px;border-radius:26px;background:radial-gradient(circle at 35% 26%,rgba(255,255,255,.94),transparent 17%),radial-gradient(circle at 72% 22%,rgba(201,170,162,.72),transparent 18%),linear-gradient(135deg,#f9f1e9 0%,#dbc6bd 100%);overflow:hidden}.brand-visual:before{content:"";position:absolute;inset:12%;border:1px solid rgba(51,35,29,.09);border-radius:999px;transform:rotate(-14deg)}.brand-visual:after{content:"Plain packaging\A Secure checkout\A Private service";white-space:pre;position:absolute;left:1.4rem;bottom:1.3rem;color:var(--lv-cocoa);font-weight:900;font-size:1.5rem;line-height:1.25}.hero-feature-products{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.8rem}.hero-mini-product{background:rgba(255,253,249,.92);border:1px solid var(--lv-line);border-radius:22px;padding:.7rem;display:grid;grid-template-columns:82px 1fr;gap:.7rem;align-items:center}.hero-mini-image,.product-image{display:block;aspect-ratio:4/5;background:var(--lv-cream);border-radius:18px;overflow:hidden}.hero-mini-image img,.product-image img{width:100%;height:100%;object-fit:cover;display:block}.hero-mini-product h3,.product-card h3{font-size:1rem;line-height:1.3;font-weight:900;margin:0;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}.hero-mini-product a,.product-card a,.guide-card a,.need-card a{color:var(--lv-cocoa);text-decoration:none}.product-price,.hero-mini-price{font-weight:950;color:var(--lv-rose-deep)}.trust-grid,.need-grid,.guide-grid{display:grid;gap:1rem}.trust-grid{grid-template-columns:repeat(4,minmax(0,1fr))}.trust-card,.need-card,.guide-card,.faq-card{background:var(--lv-card);border:1px solid var(--lv-line);border-radius:var(--lv-radius);box-shadow:0 12px 32px rgba(51,35,29,.055)}.trust-card{padding:1.2rem}.trust-card i,.need-card i{width:46px;height:46px;border-radius:999px;background:var(--lv-cream);color:var(--lv-rose-deep);display:inline-flex;align-items:center;justify-content:center;margin-bottom:.85rem}.trust-card h3,.need-card h3,.guide-card h3{font-size:1.05rem;font-weight:950;color:var(--lv-cocoa)}.trust-card p,.need-card p,.guide-card p,.product-card p{color:var(--lv-muted);line-height:1.55}.need-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.need-card{padding:1.25rem;display:flex;flex-direction:column;min-height:225px}.need-card p{flex:1}.need-card .need-link{font-weight:900;color:var(--lv-rose-deep)}.product-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:1rem}.product-card{background:var(--lv-card);border:1px solid var(--lv-line);border-radius:26px;box-shadow:0 12px 34px rgba(51,35,29,.06);overflow:hidden;display:flex;flex-direction:column;height:100%}.product-card-body{padding:1rem;display:flex;flex-direction:column;gap:.65rem;flex:1}.product-card p{margin:0;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;min-height:3.1em}.product-actions{display:grid;grid-template-columns:1fr 1fr;gap:.55rem;margin-top:auto}.guide-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.guide-card{padding:1.25rem}.guide-card .guide-link{font-weight:900;color:var(--lv-rose-deep)}.faq-card{padding:1.2rem}.accordion-item{border-color:var(--lv-line);background:#fffdf9}.accordion-button{background:#fffdf9;color:var(--lv-cocoa);font-weight:900}.accordion-button:not(.collapsed){background:var(--lv-cream);color:var(--lv-cocoa);box-shadow:none}.footer{background:#211611;color:#dfd2ca}.footer h5{color:#fff7f0;font-weight:900}.footer a{color:#fbf7f1;text-decoration:none}.footer a:hover{text-decoration:underline}.responsible-note{color:#cbb9af;font-size:.9rem}.visually-soft{color:var(--lv-muted)}@media(max-width:1199.98px){.product-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.trust-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:991.98px){.hero-grid{grid-template-columns:1fr}.hero-copy-panel,.hero-visual-panel{min-height:auto}.need-grid,.guide-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.navbar form{margin:.75rem 0!important}.navbar .header-actions{margin-top:.25rem}}@media(max-width:767.98px){.privacy-bar .container{justify-content:flex-start;font-size:.78rem;gap:.65rem}.home-section{margin:3rem auto}.section-head{align-items:flex-start;flex-direction:column}.hero-copy-panel{border-radius:24px;padding:1.2rem}.hero-copy-panel h1{font-size:2.45rem}.hero-subtitle{font-size:1rem}.hero-actions .btn{flex:1 1 100%}.hero-visual-panel{border-radius:24px}.hero-feature-products{grid-template-columns:1fr}.trust-grid,.need-grid,.guide-grid{grid-template-columns:1fr}.product-grid{grid-template-columns:repeat(2,minmax(0,1fr));gap:.75rem}.product-card-body{padding:.78rem}.product-actions{grid-template-columns:1fr}.product-actions .btn-light{display:none}.product-card p{display:none}.brand-visual{min-height:260px}.brand-visual:after{font-size:1.18rem}.container{--bs-gutter-x:1.1rem}}@media(max-width:420px){.product-grid{grid-template-columns:1fr}.hero-mini-product{grid-template-columns:76px 1fr}.navbar-brand{font-size:1rem}}
  </style>
  {% for style in styles %}<link href="{{ style.href }}" rel="{{ style.rel }}" media="{{ style.media }}">{% endfor %}
  {% if json_ld %}<script type="application/ld+json">{{ json_ld|raw }}</script>{% endif %}
</head>
<body class="d-flex flex-column min-vh-100">
<div id="alert" class="position-fixed top-0 start-50 translate-middle-x p-3" style="z-index:1080;max-width:min(92vw,720px);"></div>
<div class="privacy-bar" aria-label="Store privacy and safety promises"><div class="container"><span>18+ only</span><span>·</span><span>Discreet packaging</span><span>·</span><span>Private billing descriptor</span><span>·</span><span>Secure checkout</span></div></div>
<nav class="navbar navbar-expand-lg border-bottom sticky-top">
  <div class="container">
    <a class="navbar-brand" href="{{ home }}">{{ name }}</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="{{ home }}">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="index.php?route=product/search&language=en-gb&search=wellness">Shop</a></li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#shop-by-need" role="button" data-bs-toggle="dropdown" aria-expanded="false">Shop by Need</a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item fw-semibold" href="index.php?route=product/search&language=en-gb&search=Beginner%20Friendly">Beginner Friendly</a></li>
            <li><a class="dropdown-item fw-semibold" href="index.php?route=product/search&language=en-gb&search=Quiet%20Discreet">Quiet &amp; Discreet</a></li>
            <li><a class="dropdown-item fw-semibold" href="index.php?route=product/search&language=en-gb&search=Lingerie%20Sleepwear">Lingerie &amp; Sleepwear</a></li>
            <li><a class="dropdown-item fw-semibold" href="index.php?route=product/search&language=en-gb&search=Couples">Couples Essentials</a></li>
            <li><a class="dropdown-item fw-semibold" href="index.php?route=product/search&language=en-gb&search=App%20Controlled">App-Controlled Toys</a></li>
            <li><a class="dropdown-item fw-semibold" href="index.php?route=product/search&language=en-gb&search=Care">Accessories &amp; Care</a></li>
            {% for category in wellness_categories %}<li><hr class="dropdown-divider"></li><li><a class="dropdown-item" href="{{ category.href }}">{{ category.name }}</a></li>{% endfor %}
