parent;border-radius:999px;min-height:38px;padding-left:34px;font-size:12px;color:var(--lv-ink)}.header-search .form-control::placeholder{color:#b5a9a1}.header-icon-link{color:var(--lv-cocoa);font-size:13px;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:6px;min-height:38px}.cart-link{position:relative;width:38px;height:38px;border-radius:999px;color:var(--lv-cocoa);display:inline-flex;align-items:center;justify-content:center;text-decoration:none}.cart-link .cart-dot{position:absolute;right:5px;top:4px;width:17px;height:17px;border-radius:999px;background:#8c5a47;color:white;font-size:9px;display:inline-flex;align-items:center;justify-content:center;font-weight:900}.btn{border-radius:999px;font-weight:800;min-height:42px;display:inline-flex;align-items:center;justify-content:center;gap:.45rem;white-space:nowrap;font-size:13px}.btn-primary{--bs-btn-bg:#2a1912;--bs-btn-border-color:#2a1912;--bs-btn-hover-bg:#140b08;--bs-btn-hover-border-color:#140b08;--bs-btn-active-bg:#140b08;--bs-btn-active-border-color:#140b08}.btn-light{background:#fffaf7;border-color:var(--lv-line);color:var(--lv-cocoa)}.form-control,.form-select{border-radius:14px;border-color:var(--lv-line);min-height:42px}.form-control:focus,.form-select:focus{border-color:var(--lv-rose);box-shadow:0 0 0 .18rem rgba(184,121,106,.18)}.home-commerce{background:var(--lv-ivory)}.home-hero{min-height:540px;display:flex;align-items:center;position:relative;overflow:hidden;background:#f6ded0 url("image/catalog/lovanest/home-hero.png") center right/cover no-repeat}.home-hero:before{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(255,250,245,.98) 0 42%,rgba(255,250,245,.48) 58%,rgba(255,250,245,0) 100%);z-index:1}.hero-copy{position:relative;z-index:2;max-width:530px;padding:82px 0}.hero-kicker{display:block;color:#2f221d;text-transform:uppercase;font-size:13px;font-weight:900;letter-spacing:.12em;margin-bottom:18px}.hero-copy h1{font-family:Georgia,"Times New Roman",serif;font-weight:700;font-size:clamp(48px,4.7vw,72px);line-height:.98;letter-spacing:-.055em;margin:0 0 20px;color:#241914}.hero-copy h1 em{font-style:italic;font-weight:400;color:#a96f61}.hero-subtitle{font-size:17px;line-height:1.66;color:#63534c;max-width:470px;margin:0 0 24px}.hero-actions{display:flex;gap:13px;flex-wrap:wrap}.hero-actions .btn{min-height:46px;padding:0 23px}.hero-trust-points{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:18px;padding:24px 0;color:#3d302a;font-size:12px;font-weight:800}.hero-trust-points span{display:inline-flex;align-items:center;gap:8px}.home-section{margin:42px auto}.section-head{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:16px}.section-head h2,.section-title{font-family:Georgia,"Times New Roman",serif;font-size:28px;font-weight:700;letter-spacing:-.03em;color:#241914;margin:0}.section-head .btn{min-height:34px;padding:0 15px;border-color:var(--lv-line);background:#fffaf7;color:#3a281f;font-size:11px}.need-grid{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:13px}.need-card{background:var(--lv-card);border:1px solid var(--lv-line);border-radius:12px;overflow:hidden;box-shadow:0 8px 24px rgba(60,39,29,.045);min-height:282px;display:flex;flex-direction:column;text-decoration:none;color:var(--lv-ink);transition:transform .18s ease,box-shadow .18s ease}.need-card:hover{transform:translateY(-3px);box-shadow:0 15px 28px rgba(60,39,29,.09)}.need-card-visual{height:172px;background:linear-gradient(135deg,#f8e9e2,#fffaf5);display:flex;align-items:center;justify-content:center;overflow:hidden}.need-card-visual img{width:100%;height:100%;object-fit:cover}.need-card-copy{padding:13px}.need-card h3{font-size:14px;font-weight:900;margin:0 0 7px;line-height:1.25;color:#2b1d17}.need-card p{font-size:12px;line-height:1.45;margin:0 0 12px;color:#6d5f58}.need-card .need-link{font-size:12px;font-weight:900;color:#3a281f}.product-grid{display:grid;grid-template-colu