:170px;border-radius:10px;background:linear-gradient(135deg,#ead5ca,#fffaf5);margin-bottom:12px;overflow:hidden;position:relative}.blog-image img{width:100%;height:100%;object-fit:cover;mix-blend-mode:multiply}.blog-image.blog-packaging:before,.blog-image.blog-care:before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 62% 46%,rgba(52,32,24,.78) 0 12%,transparent 12.5%),linear-gradient(135deg,rgba(255,255,255,.35),rgba(165,112,88,.25))}.blog-image.blog-care:before{background:radial-gradient(ellipse at 64% 45%,rgba(219,126,146,.75) 0 14%,transparent 14.5%),linear-gradient(135deg,rgba(255,255,255,.35),rgba(165,112,88,.25))}.blog-card h3{font-size:14px;line-height:1.25;font-weight:900;margin:0 0 8px}.blog-meta{font-size:12px;color:#8b7a70}.faq-card{background:transparent;border:0;box-shadow:none}.faq-list{border-top:1px solid var(--lv-line)}.faq-item{border-bottom:1px solid var(--lv-line)}.accordion-item{border:0;background:transparent}.accordion-button{background:transparent!important;color:#2a1912!important;font-size:13px;font-weight:900;padding:14px 0;box-shadow:none!important}.accordion-button:after{width:14px;height:14px;background-size:14px}.accordion-body{padding:0 0 14px;color:#6d5f58;font-size:13px}.footer{background:#f6ece4;color:#44342d;border-top:1px solid var(--lv-line);padding:46px 0!important}.footer h5{color:#241914;font-size:13px;font-weight:900;margin-bottom:14px}.footer p,.footer li,.footer a,.responsible-note{color:#6f6159;font-size:12px;line-height:1.65}.footer a{text-decoration:none}.footer a:hover{color:#241914;text-decoration:underline}.footer-social{display:flex;gap:17px;margin-top:16px}.footer-social a{width:22px;height:22px;display:inline-flex;align-items:center;justify-content:center;color:#241914}.brand-footer-title{font-family:Georgia,"Times New Roman",serif;color:#241914;font-size:18px;font-weight:700;margin-bottom:12px}@media(max-width:1199.98px){.need-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.product-grid{grid-template-columns:repeat(3,minmax(0,1fr))}}@media(max-width:991.98px){.site-header .navbar{min-height:auto;padding:18px 0}.navbar-nav{gap:4px;margin-top:16px}.header-search{width:100%;margin:12px 0}.header-actions{width:100%;justify-content:space-between}.home-hero{min-height:430px}.hero-copy{padding:50px 0}.hero-copy h1{font-size:42px}.hero-subtitle{font-size:15px}.hero-actions .btn{flex:1 1 100%}.hero-trust-points{grid-template-columns:1fr;gap:10px}.section-head h2,.section-title{font-size:24px}.need-grid{grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}.need-card-visual{height:135px}.product-grid{grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}.product-card h3{font-size:13px}.beginner-banner{padding:28px 22px;min-height:190px}.beginner-banner h2{font-size:24px}.brand-word{font-size:24px}.container{--bs-gutter-x:1.1rem}}@media(max-width:420px){.need-grid,.product-grid{grid-template-columns:1fr}.need-card{min-height:auto}.product-image{aspect-ratio:1/1}}
