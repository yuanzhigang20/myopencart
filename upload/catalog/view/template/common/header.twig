<!doctype html>
<html dir="{{ direction }}" lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <base href="{{ base }}">
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  {% if keywords %}<meta name="keywords" content="{{ keywords }}">{% endif %}
  <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1">
  <meta property="og:site_name" content="{{ name }}">
  <meta property="og:title" content="{{ title }}">
  {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ current_url }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  {% if description %}<meta name="twitter:description" content="{{ description }}">{% endif %}
  {% for link in links %}<link href="{{ link.href }}" rel="{{ link.rel }}">{% endfor %}
  {% for meta in metas %}<meta{% for key, value in meta %} {{ key }}="{{ value }}"{% endfor %}>{% endfor %}
  {% if icon %}<link rel="icon" href="{{ icon }}">{% endif %}
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
  <style>
    :root{--lv-cream:#fbf7f1;--lv-soft:#f3ece7;--lv-rose:#c7aaa1;--lv-mauve:#8f7370;--lv-ink:#241b18;--lv-brown:#3a2b25;--lv-muted:#746761;--lv-line:#eadfd8;--lv-gold:#b48b62;--lv-success:#4d6b57}html{scroll-behavior:smooth}body{background:var(--lv-cream);color:var(--lv-ink);font-family:Inter,ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif;letter-spacing:.01em}.navbar{background:rgba(251,247,241,.94)!important;backdrop-filter:blur(18px);border-color:var(--lv-line)!important}.navbar-brand{font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:var(--lv-ink)!important}.nav-link{color:var(--lv-muted)!important;font-weight:600}.nav-link:hover{color:var(--lv-ink)!important}.btn{border-radius:999px;font-weight:700;min-height:44px;display:inline-flex;align-items:center;justify-content:center;gap:.45rem}.btn-primary{--bs-btn-bg:var(--lv-brown);--bs-btn-border-color:var(--lv-brown);--bs-btn-hover-bg:#211815;--bs-btn-hover-border-color:#211815;--bs-btn-active-bg:#211815;--bs-btn-active-border-color:#211815}.btn-outline-primary{--bs-btn-color:var(--lv-brown);--bs-btn-border-color:rgba(58,43,37,.35);--bs-btn-hover-bg:var(--lv-brown);--bs-btn-hover-border-color:var(--lv-brown)}.btn-light{background:#fff;border-color:var(--lv-line);color:var(--lv-brown)}.form-control,.form-select{border-radius:16px;border-color:var(--lv-line);min-height:44px}.form-control:focus,.form-select:focus{border-color:var(--lv-rose);box-shadow:0 0 0 .2rem rgba(199,170,161,.24)}.oc-hero{position:relative;overflow:hidden;background:radial-gradient(circle at 78% 18%,rgba(199,170,161,.42),transparent 34%),linear-gradient(135deg,#fff8f1 0%,#f1e4dc 48%,#2b201c 100%);color:var(--lv-ink);border:1px solid var(--lv-line);border-radius:34px;box-shadow:0 24px 80px rgba(58,43,37,.12)}.oc-hero:after{content:"";position:absolute;right:-130px;bottom:-170px;width:430px;height:430px;border-radius:999px;background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.25)}.hero-kicker,.wellness-kicker{display:inline-flex;align-items:center;gap:.5rem;border:1px solid var(--lv-line);background:rgba(255,255,255,.72);color:var(--lv-brown);border-radius:999px;padding:.45rem .8rem;font-weight:800;font-size:.78rem;letter-spacing:.08em;text-transform:uppercase}.hero-copy{color:#5f514b;max-width:680px}.trust-strip{background:#fff;border:1px solid var(--lv-line);border-radius:24px;box-shadow:0 16px 40px rgba(58,43,37,.06)}.trust-item{display:flex;gap:.8rem;align-items:flex-start}.trust-item i{color:var(--lv-gold);font-size:1.1rem;margin-top:.2rem}.trust-item strong{display:block;color:var(--lv-ink)}.trust-item span{display:block;color:var(--lv-muted);font-size:.9rem}.scenario-card{height:100%;padding:1.15rem;border:1px solid var(--lv-line);border-radius:24px;background:#fff;color:var(--lv-ink);text-decoration:none;transition:.2s;box-shadow:0 10px 28px rgba(58,43,37,.05)}.scenario-card:hover{transform:translateY(-3px);box-shadow:0 18px 42px rgba(58,43,37,.09);color:var(--lv-ink)}.scenario-card i{width:44px;height:44px;border-radius:50%;background:var(--lv-soft);display:inline-flex;align-items:center;justify-content:center;color:var(--lv-brown);margin-bottom:.85rem}.product-card{transition:.2s;overflow:hidden;background:#fff;border:1px solid var(--lv-line)!important;border-radius:26px;box-shadow:0 12px 34px rgba(58,43,37,.06)!important}.product-card:hover{transform:translateY(-4px);box-shadow:0 20px 48px rgba(58,43,37,.12)!important}.product-card .product-image-wrap{display:block;aspect-ratio:4/5;background:linear-gradient(180deg,#fbf7f1,#efe3dc);overflow:hidden}.product-card img{width:100%;height:100%;object-fit:cover;display:block}.product-card .card-body{padding:1.15rem}.product-card h3{line-height:1.35}.product-card .text-muted{color:var(--lv-muted)!important}.product-badges{display:flex;flex-wrap:wrap;gap:.35rem;margin:.35rem 0 .8rem}.wellness-pill{display:inline-flex;align-items:center;border:1px solid var(--lv-line);background:var(--lv-soft);color:var(--lv-brown);border-radius:999px;font-size:.72rem;font-weight:800;padding:.28rem .55rem}.price{font-size:1.2rem;font-weight:900;color:var(--lv-brown)}.footer{background:#211815;color:#d8cbc3}.footer a{color:#fbf7f1;text-decoration:none}.footer a:hover{text-decoration:underline}.age-note{font-size:.78rem;color:var(--lv-muted)}.product-gallery-main{background:#fff;border:1px solid var(--lv-line);border-radius:28px;overflow:hidden}.product-gallery-main img{width:100%;aspect-ratio:4/5;object-fit:cover}.product-summary-card{background:#fff;border:1px solid var(--lv-line);border-radius:28px;padding:1.4rem;box-shadow:0 18px 44px rgba(58,43,37,.08)}.spec-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.75rem}.spec-tile{background:#fff;border:1px solid var(--lv-line);border-radius:18px;padding:.9rem}.spec-tile small{display:block;color:var(--lv-muted);font-weight:700}.spec-tile strong{color:var(--lv-ink)}.wellness-section{background:#fff;border:1px solid var(--lv-line);border-radius:28px;padding:1.4rem}.accordion-button{background:#fff;color:var(--lv-ink);font-weight:800}.accordion-button:not(.collapsed){background:var(--lv-soft);color:var(--lv-ink);box-shadow:none}.accordion-item{border-color:var(--lv-line)}.sticky-atc{display:none}.breadcrumb a{color:var(--lv-muted)}img[loading="lazy"]{content-visibility:auto}@media(max-width:767.98px){body{padding-bottom:84px}.oc-hero{border-radius:24px}.display-4,.display-5{font-size:2.15rem}.hero-actions .btn{width:100%;margin-bottom:.65rem}.navbar .d-flex.gap-2{margin-top:.75rem}.navbar form{margin:.75rem 0!important}.trust-strip{border-radius:20px}.spec-grid{grid-template-columns:1fr}.sticky-atc{position:fixed;left:0;right:0;bottom:0;z-index:1030;display:flex;align-items:center;justify-content:space-between;gap:.75rem;background:rgba(251,247,241,.97);border-top:1px solid var(--lv-line);padding:.75rem 1rem;box-shadow:0 -12px 34px rgba(58,43,37,.12)}.sticky-atc .btn{white-space:nowrap}.product-card .product-image-wrap{aspect-ratio:1/1}.container{--bs-gutter-x:1.1rem}}
  </style>
  {% for style in styles %}<link href="{{ style.href }}" rel="{{ style.rel }}" media="{{ style.media }}">{% endfor %}
  {% if json_ld %}<script type="application/ld+json">{{ json_ld|raw }}</script>{% endif %}
</head>
<body class="d-flex flex-column min-vh-100">
<div class="py-2 text-center small" style="background:#211815;color:#f7eee7;">18+ only · Discreet packaging · Private billing descriptor · Secure checkout</div>
<nav class="navbar navbar-expand-lg border-bottom sticky-top">
  <div class="container">
    <a class="navbar-brand" href="{{ home }}">{{ name }}</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="{{ home }}">Home</a></li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Shop by Need</a>
          <ul class="dropdown-menu">
            {% for category in wellness_categories %}<li><a class="dropdown-item" href="{{ category.href }}">{{ category.name }}</a></li>{% endfor %}
          </ul>
        </li>
        <li class="nav-item"><a class="nav-link" href="{{ contact }}">Contact</a></li>
        <li class="nav-item"><a class="nav-link" href="{{ shopping_cart }}">Cart</a></li>
      </ul>
      <form class="d-flex me-3" action="index.php" method="get" role="search">
        <input type="hidden" name="route" value="product/search">
        <input class="form-control" name="search" placeholder="Search private wellness products" aria-label="Search private wellness products">
      </form>
      <div class="d-flex gap-2">
        {% if logged %}<a class="btn btn-outline-primary" href="{{ account }}">Account</a><a class="btn btn-primary" href="{{ logout }}">Logout</a>{% else %}<a class="btn btn-outline-primary" href="{{ login }}">Login</a><a class="btn btn-primary" href="{{ register }}">Register</a>{% endif %}
      </div>
    </div>
  </div>
</nav>
{{ menu }}
