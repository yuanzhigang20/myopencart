<!doctype html>
<html dir="{{ direction }}" lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <base href="{{ base }}">
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  {% if keywords %}<meta name="keywords" content="{{ keywords }}">{% endif %}
  <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1">
  <meta property="og:site_name" content="{{ name }}">
  <meta property="og:title" content="{{ title }}">
  {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ current_url }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  {% if description %}<meta name="twitter:description" content="{{ description }}">{% endif %}
  {% for link in links %}<link href="{{ link.href }}" rel="{{ link.rel }}">{% endfor %}
  {% for meta in metas %}<meta{% for key, value in meta %} {{ key }}="{{ value }}"{% endfor %}>{% endfor %}
  {% if icon %}<link rel="icon" href="{{ icon }}">{% endif %}
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
  <style>
    body{background:#f6f7fb;color:#172033}.navbar-brand{font-weight:800;letter-spacing:.2px}.oc-hero{background:linear-gradient(135deg,#111827,#2563eb 55%,#06b6d4);color:#fff;border-radius:28px}.product-card{transition:.2s;overflow:hidden}.product-card:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(15,23,42,.14)}.product-card img{height:190px;object-fit:cover;background:#eef2ff}.price{font-size:1.15rem;font-weight:800;color:#dc2626}.footer{background:#111827;color:#cbd5e1}.footer a{color:#e5e7eb;text-decoration:none}
  </style>
  {% for style in styles %}<link href="{{ style.href }}" rel="{{ style.rel }}" media="{{ style.media }}">{% endfor %}
  {% if json_ld %}<script type="application/ld+json">{{ json_ld|raw }}</script>{% endif %}
</head>
<body class="d-flex flex-column min-vh-100">
<nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top">
  <div class="container">
    <a class="navbar-brand" href="{{ home }}">{{ name }}</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"><span class="navbar-toggler-icon"></span></button>
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="{{ home }}">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="{{ contact }}">Contact</a></li>
        <li class="nav-item"><a class="nav-link" href="{{ shopping_cart }}">Cart</a></li>
      </ul>
      <form class="d-flex me-3" action="index.php" method="get">
        <input type="hidden" name="route" value="product/search">
        <input class="form-control" name="search" placeholder="Search products">
      </form>
      <div class="d-flex gap-2">
        {% if logged %}<a class="btn btn-outline-primary" href="{{ account }}">Account</a><a class="btn btn-primary" href="{{ logout }}">Logout</a>{% else %}<a class="btn btn-outline-primary" href="{{ login }}">Login</a><a class="btn btn-primary" href="{{ register }}">Register</a>{% endif %}
      </div>
    </div>
  </div>
</nav>
{{ menu }}
