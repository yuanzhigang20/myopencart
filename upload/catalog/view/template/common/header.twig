        <li class="nav-item"><a class="nav-link" href="/blog/">Blog</a></li>
        <li class="nav-item"><a class="nav-link" href="{{ contact }}">Contact</a></li>
      </ul>
      <form class="d-flex me-3" action="index.php" method="get" role="search">
        <input type="hidden" name="route" value="product/search">
        <input class="form-control" name="search" placeholder="Search" aria-label="Search private wellness products">
      </form>
      <div class="d-flex gap-2 header-actions">
        {% if logged %}<a class="btn btn-outline-primary" href="{{ account }}">Account</a>{% else %}<a class="btn btn-outline-primary" href="{{ login }}">Login</a>{% endif %}
        <a class="btn btn-primary" href="{{ shopping_cart }}"><i class="fa-solid fa-bag-shopping"></i> Cart</a>
      </div>
    </div>
  </div>
