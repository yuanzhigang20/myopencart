{{ header }}
<main class="container py-4">
  <section class="oc-hero p-4 p-lg-5 mb-4">
    <div class="row align-items-center g-5 position-relative">
      <div class="col-lg-7">
        <span class="hero-kicker mb-3"><i class="fa-solid fa-shield-heart"></i> Private Wellness Ecommerce · 18+</span>
        <h1 class="display-4 fw-bold mb-3">Discreet Intimacy Essentials</h1>
        <p class="lead hero-copy mb-4">Clean, private and carefully curated sexual wellness and intimacy products for adults. Designed around comfort, body-safe materials, secure checkout and discreet delivery.</p>
        <div class="hero-actions d-flex flex-wrap gap-2 mb-4">
          <a class="btn btn-primary btn-lg" href="#products"><i class="fa-solid fa-bag-shopping"></i> Shop Essentials</a>
          <a class="btn btn-light btn-lg" href="#shop-by-need"><i class="fa-solid fa-sparkles"></i> Shop by Need</a>
        </div>
        <div class="d-flex flex-wrap gap-2 age-note">
          <span class="wellness-pill">18+ only</span>
          <span class="wellness-pill">Discreet packaging</span>
          <span class="wellness-pill">Secure payment</span>
          <span class="wellness-pill">Body-safe focus</span>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="trust-strip p-4">
          <h2 class="h5 fw-bold mb-3">Private by design</h2>
          <div class="vstack gap-3">
            <div class="trust-item"><i class="fa-solid fa-box"></i><div><strong>Discreet Packaging</strong><span>Plain outer packaging with no explicit wording.</span></div></div>
            <div class="trust-item"><i class="fa-solid fa-credit-card"></i><div><strong>Private Billing</strong><span>Checkout built for secure, low-friction payment.</span></div></div>
            <div class="trust-item"><i class="fa-solid fa-leaf"></i><div><strong>Body-safe Materials</strong><span>Product pages highlight materials, care and safe use.</span></div></div>
            <div class="trust-item"><i class="fa-solid fa-user-lock"></i><div><strong>Adults Only</strong><span>Positioned as responsible private wellness retail.</span></div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="trust-strip p-3 p-lg-4 mb-5" aria-label="Store trust benefits">
    <div class="row g-3 row-cols-1 row-cols-sm-2 row-cols-lg-5">
      <div class="col trust-item"><i class="fa-solid fa-box-open"></i><div><strong>Discreet Packaging</strong><span>Plain parcel</span></div></div>
      <div class="col trust-item"><i class="fa-solid fa-file-invoice"></i><div><strong>Private Billing</strong><span>Clean descriptors</span></div></div>
      <div class="col trust-item"><i class="fa-solid fa-lock"></i><div><strong>Secure Checkout</strong><span>Encrypted flow</span></div></div>
      <div class="col trust-item"><i class="fa-solid fa-certificate"></i><div><strong>Body-safe Focus</strong><span>Material details</span></div></div>
      <div class="col trust-item"><i class="fa-solid fa-truck-fast"></i><div><strong>Fast Shipping</strong><span>Clear delivery info</span></div></div>
    </div>
  </section>

  <section id="shop-by-need" class="mb-5">
    <div class="d-flex justify-content-between align-items-end mb-3">
      <div>
        <span class="wellness-kicker mb-2">Shop by comfort level</span>
        <h2 class="fw-bold mb-1">Find products by scenario</h2>
        <p class="text-muted mb-0">Less explicit browsing, clearer intent, better conversion.</p>
      </div>
    </div>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-3">
      <div class="col"><a class="scenario-card d-block" href="index.php?route=product/search&language=en-gb&search=Beginner%20Friendly"><i class="fa-solid fa-seedling"></i><h3 class="h6 fw-bold">Beginner Friendly</h3><p class="small text-muted mb-0">Simple, approachable essentials.</p></a></div>
      <div class="col"><a class="scenario-card d-block" href="index.php?route=product/search&language=en-gb&search=For%20Couples"><i class="fa-solid fa-heart"></i><h3 class="h6 fw-bold">For Couples</h3><p class="small text-muted mb-0">Shared intimacy and connection.</p></a></div>
      <div class="col"><a class="scenario-card d-block" href="index.php?route=product/search&language=en-gb&search=Solo%20Wellness"><i class="fa-solid fa-spa"></i><h3 class="h6 fw-bold">Solo Wellness</h3><p class="small text-muted mb-0">Private self-care selections.</p></a></div>
      <div class="col"><a class="scenario-card d-block" href="index.php?route=product/search&language=en-gb&search=Quiet%20Discreet"><i class="fa-solid fa-volume-xmark"></i><h3 class="h6 fw-bold">Quiet & Discreet</h3><p class="small text-muted mb-0">Low-profile choices.</p></a></div>
      <div class="col"><a class="scenario-card d-block" href="index.php?route=product/search&language=en-gb&search=Waterproof"><i class="fa-solid fa-droplet"></i><h3 class="h6 fw-bold">Waterproof</h3><p class="small text-muted mb-0">Carefully labeled water-safe items.</p></a></div>
      <div class="col"><a class="scenario-card d-block" href="index.php?route=product/search&language=en-gb&search=Lubricants%20Care"><i class="fa-solid fa-hand-holding-droplet"></i><h3 class="h6 fw-bold">Lubricants & Care</h3><p class="small text-muted mb-0">Comfort, care and cleaning.</p></a></div>
      <div class="col"><a class="scenario-card d-block" href="index.php?route=product/search&language=en-gb&search=Gift%20Sets"><i class="fa-solid fa-gift"></i><h3 class="h6 fw-bold">Gift Sets</h3><p class="small text-muted mb-0">Tasteful private gifting.</p></a></div>
      <div class="col"><a class="scenario-card d-block" href="index.php?route=product/category&language=en-gb&path=101"><i class="fa-solid fa-border-all"></i><h3 class="h6 fw-bold">All Essentials</h3><p class="small text-muted mb-0">Browse the full catalog.</p></a></div>
    </div>
  </section>

  <section id="products" class="mb-5">
    <div class="d-flex justify-content-between align-items-end mb-3">
      <div><span class="wellness-kicker mb-2">Curated catalog</span><h2 class="fw-bold mb-1">Featured private wellness products</h2><p class="text-muted mb-0">Clean product pages with clear benefits, privacy notes and safe-use guidance.</p></div>
    </div>
    {% if products %}
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
      {% for product in products %}
      <div class="col">
        <div class="card product-card h-100">
          <a class="product-image-wrap" href="{{ product.href }}"><img src="{{ product.thumb }}" class="card-img-top" alt="{{ product.name }} private wellness product" loading="lazy" width="360" height="450"></a>
          <div class="card-body d-flex flex-column">
            <h3 class="h6 fw-bold"><a class="text-decoration-none text-dark" href="{{ product.href }}">{{ product.name }}</a></h3>
            <div class="product-badges"><span class="wellness-pill">Discreet</span><span class="wellness-pill">18+</span><span class="wellness-pill">Private delivery</span></div>
            <p class="text-muted small flex-grow-1">{{ product.description }}</p>
            <div class="price mb-3">{{ product.price }}</div>
            <a class="btn btn-primary mt-auto" href="{{ product.href }}">View details</a>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
    {% else %}<div class="alert alert-warning">No products yet. Add products in admin panel.</div>{% endif %}
  </section>

  <section class="wellness-section mb-5">
    <div class="row g-4 align-items-start">
      <div class="col-lg-5"><span class="wellness-kicker mb-2">Responsible wellness</span><h2 class="fw-bold">A cleaner alternative to low-trust adult retail</h2></div>
      <div class="col-lg-7"><p class="text-muted mb-3">Lovanest is structured as a private wellness store: calm visual design, minimal explicit wording, transparent product details, secure checkout and clear privacy expectations.</p><p class="mb-0 age-note">This website is intended for adults 18+. Age notice is visible without blocking search engines from crawling public content.</p></div>
    </div>
  </section>
</main>
{{ footer }}
