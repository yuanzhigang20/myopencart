{{ header }}
<main class="home-commerce">
  <section class="home-hero-compact">
    <div class="container">
      <div class="hero-commerce-grid">
        <div class="hero-commerce-copy">
          <span class="hero-kicker mb-2"><i class="fa-solid fa-shield-heart"></i> Private Wellness Ecommerce · 18+</span>
          <h1 class="fw-bold mb-2">Discreet Intimacy Essentials</h1>
          <p class="hero-copy mb-3">Body-safe products, private packaging, and a softer way to shop intimate wellness.</p>
          <div class="hero-actions d-flex flex-wrap gap-2 mb-3">
            <a class="btn btn-primary btn-lg" href="#all-products"><i class="fa-solid fa-bag-shopping"></i> Shop Products</a>
            <a class="btn btn-light btn-lg" href="index.php?route=product/search&language=en-gb&search=Beginner%20Friendly"><i class="fa-solid fa-seedling"></i> Beginner Friendly</a>
          </div>
          <div class="hero-trust-line">18+ only · Discreet packaging · Secure PayPal checkout</div>
        </div>

        <div class="hero-commerce-featured" aria-label="Featured shopping entry points">
          {% for product in hero_products %}
            <article class="hero-mini-product">
              <a href="{{ product.href }}" class="hero-mini-image"><img src="{{ product.thumb }}" alt="{{ product.name }}" width="120" height="150"></a>
              <div class="hero-mini-body">
                <span class="wellness-pill">Best Seller</span>
                <h2 class="h6 fw-bold mb-1"><a href="{{ product.href }}">{{ product.name }}</a></h2>
                <div class="hero-mini-price">{{ product.price }}</div>
                <div class="d-flex gap-2 mt-2">
                  <form action="{{ cart_add }}" method="post" data-oc-toggle="ajax" data-oc-load="{{ cart }}" data-oc-target="#cart" class="m-0 flex-fill">
                    <input type="hidden" name="product_id" value="{{ product.product_id }}">
                    <input type="hidden" name="quantity" value="1">
                    <button class="btn btn-primary btn-sm w-100" type="submit">Add</button>
                  </form>
                  <a class="btn btn-light btn-sm" href="{{ product.href }}">View</a>
                </div>
              </div>
            </article>
          {% endfor %}
          <a class="hero-need-card" href="index.php?route=product/search&language=en-gb&search=Quiet%20Discreet">
            <span class="wellness-pill">Quiet & Discreet</span>
            <strong>Low-profile essentials</strong>
            <small>Shop privacy-first picks</small>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="shop-by-need" class="container home-section shop-need-section">
    <div class="section-head compact-head">
      <div>
        <span class="wellness-kicker mb-2">Shop by Need</span>
        <h2 class="fw-bold mb-1">Choose by comfort, use case, or privacy level</h2>
      </div>
      <a class="btn btn-outline-primary" href="{{ all_products_url }}">Browse all</a>
    </div>
    <div class="need-scroll">
      {% for category in category_groups %}
        <article class="need-card">
          <i class="fa-solid fa-layer-group"></i>
          <h3>{{ category.name }}</h3>
          <p>{% if category.children %}{{ category.children|length }} curated collections{% else %}Browse the full collection{% endif %}</p>
          <a href="{{ category.href }}">Shop category</a>
          {% if category.children %}
            <div class="mt-2 d-flex flex-wrap gap-1">
              {% for child in category.children|slice(0, 4) %}<a class="wellness-pill text-decoration-none" href="{{ child.href }}">{{ child.name }}</a>{% endfor %}
            </div>
          {% endif %}
        </article>
      {% else %}
        <article class="need-card"><i class="fa-solid fa-layer-group"></i><h3>All Products</h3><p>Browse every available private wellness product.</p><a href="{{ all_products_url }}">Shop now</a></article>
      {% endfor %}
    </div>
  </section>

  <section id="all-products" class="container home-section products-front-section">
    <div class="section-head compact-head">
      <div>
        <span class="wellness-kicker mb-2">All Products</span>
        <h2 class="fw-bold mb-1">Browse the full private wellness catalog</h2>
        <p class="text-muted mb-0">All available products with clear price, benefit, and fast cart actions.</p>
      </div>
    </div>
    {% if products %}
      <div class="home-product-grid">
        {% for product in products %}
          <article class="home-product-card">
            <a class="home-product-image" href="{{ product.href }}"><img src="{{ product.thumb }}" alt="{{ product.name }} private wellness product" loading="{% if loop.index <= 4 %}eager{% else %}lazy{% endif %}" width="360" height="450"></a>
            <div class="home-product-body">
              <h3><a href="{{ product.href }}">{{ product.name }}</a></h3>
              <p>{{ product.short_benefit }}</p>
              <div class="home-product-price">{{ product.price }}</div>
              <div class="home-product-actions">
                <form action="{{ cart_add }}" method="post" data-oc-toggle="ajax" data-oc-load="{{ cart }}" data-oc-target="#cart" class="m-0">
                  <input type="hidden" name="product_id" value="{{ product.product_id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button class="btn btn-primary" type="submit">Add to Cart</button>
                </form>
                <a class="btn btn-light" href="{{ product.href }}">View Details</a>
              </div>
            </div>
          </article>
        {% endfor %}
      </div>
      <div class="row mt-4 align-items-center">
        <div class="col-md-6">{{ pagination }}</div>
        <div class="col-md-6 text-md-end small text-muted">{{ results }}</div>
      </div>
    {% else %}<div class="alert alert-warning">No products yet. Add products in admin panel.</div>{% endif %}
  </section>

  <section class="container home-section">
    <div class="promise-card">
      <div>
        <span class="wellness-kicker mb-2">Discreet Shopping Promise</span>
        <h2 class="fw-bold mb-2">Private, clean, and confidence-first</h2>
        <p class="text-muted mb-0">Orders ship in plain packaging. Product pages avoid explicit presentation and focus on material, care, comfort, and secure checkout.</p>
      </div>
      <div class="promise-points">
        <div><i class="fa-solid fa-box"></i><strong>Plain parcel</strong><span>No adult wording outside.</span></div>
        <div><i class="fa-brands fa-paypal"></i><strong>Secure PayPal</strong><span>Trusted payment flow.</span></div>
        <div><i class="fa-solid fa-user-shield"></i><strong>18+ responsible retail</strong><span>Visible notice, non-blocking crawl.</span></div>
      </div>
    </div>
  </section>

  <section id="new-arrivals" class="container home-section products-front-section">
    <div class="section-head compact-head">
      <div>
        <span class="wellness-kicker mb-2">New Arrivals</span>
        <h2 class="fw-bold mb-1">Freshly added essentials</h2>
      </div>
    </div>
    {% if new_arrivals %}
      <div class="home-product-grid home-product-grid-small">
        {% for product in new_arrivals %}
          <article class="home-product-card compact-product-card">
            <a class="home-product-image" href="{{ product.href }}"><img src="{{ product.thumb }}" alt="{{ product.name }} private wellness product" loading="lazy" width="360" height="450"></a>
            <div class="home-product-body">
              <h3><a href="{{ product.href }}">{{ product.name }}</a></h3>
              <div class="home-product-price">{{ product.price }}</div>
              <a class="btn btn-light w-100" href="{{ product.href }}">View Details</a>
            </div>
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </section>

  <section class="container home-section faq-section">
    <div class="wellness-section">
      <span class="wellness-kicker mb-2">FAQ</span>
      <h2 class="fw-bold mb-3">Private shopping questions</h2>
      <div class="accordion" id="homeFaq">
        <div class="accordion-item"><h3 class="accordion-header"><button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faqOne">Will the package show adult product names?</button></h3><div id="faqOne" class="accordion-collapse collapse show" data-bs-parent="#homeFaq"><div class="accordion-body text-muted">No. Orders are prepared for plain, discreet outer packaging without explicit wording.</div></div></div>
        <div class="accordion-item"><h3 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faqTwo">Is checkout secure?</button></h3><div id="faqTwo" class="accordion-collapse collapse" data-bs-parent="#homeFaq"><div class="accordion-body text-muted">Checkout is designed around secure PayPal payment and a low-friction order summary.</div></div></div>
        <div class="accordion-item"><h3 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faqThree">Is this site for adults only?</button></h3><div id="faqThree" class="accordion-collapse collapse" data-bs-parent="#homeFaq"><div class="accordion-body text-muted">Yes. Lovanest is intended for adults 18+ and uses a clean private wellness presentation.</div></div></div>
      </div>
    </div>
  </section>
</main>
{{ footer }}
